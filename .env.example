# ── Discord ────────────────────────────────────────────────────────────────────
# Main bot token (required)
DISCORD_TOKEN=

# Second bot token for !ai battle (optional)
DISCORD_TOKEN_2=

# ── AI / Image generation ──────────────────────────────────────────────────────
# Groq API key — enables AI chat, trivia, conspiracy, voice (optional)
GROQ_API_KEY=

# HuggingFace token — enables !image / /image (optional)
HUGGINGFACE_TOKEN=

# ── Music ──────────────────────────────────────────────────────────────────────
# Suno AI key — enables !music generator and !credits (optional)
SUNO_API_KEY=

# ── Database ───────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
# e.g. mongodb+srv://user:password@cluster.mongodb.net/dbname
DATABASE_URL=

# AES-256-GCM encryption key for sensitive fields (quest progress, stats, scores)
# Must be a 64-character hex string (= 32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8080
